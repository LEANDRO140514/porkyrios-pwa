# 🔐 Variables de Entorno - Porkyrios
# Copia este archivo como .env.local y configura tus credenciales

# ====================================
# 🗄️ TURSO DATABASE
# ====================================
# Obtén estas credenciales en https://turso.tech
# 1. Crear cuenta en Turso
# 2. Crear base de datos: turso db create porkyrios
# 3. Obtener URL: turso db show porkyrios --url
# 4. Crear token: turso db tokens create porkyrios

DATABASE_URL=libsql://[tu-database].turso.io
DATABASE_AUTH_TOKEN=[tu-auth-token-aqui]

# ====================================
# 🔐 SEGURIDAD
# ====================================
# Contraseña para acceder al panel de administración (/admin)
# ⚠️ CAMBIAR EN PRODUCCIÓN
ADMIN_PASSWORD=PORKYRIOS2025

# ====================================
# 🔑 AUTENTICACIÓN OAUTH (Google & Facebook)
# ====================================
# Google OAuth - https://console.cloud.google.com
# 1. Ir a console.cloud.google.com → Crear proyecto
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs:
#    - Development: http://localhost:3000/api/auth/callback/google
#    - Production: https://tudominio.com/api/auth/callback/google
# 5. Copiar Client ID y Client Secret

GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz

# Facebook OAuth - https://developers.facebook.com
# 1. Ir a developers.facebook.com → My Apps → Create App
# 2. App Type: Business → Use case: Other
# 3. Settings → Basic → Copiar App ID y App Secret
# 4. Facebook Login → Settings → Valid OAuth Redirect URIs:
#    - Development: http://localhost:3000/api/auth/callback/facebook
#    - Production: https://tudominio.com/api/auth/callback/facebook
# 5. IMPORTANTE: Activar "Use Strict Mode for Redirect URIs"

FACEBOOK_CLIENT_ID=1234567890123456
FACEBOOK_CLIENT_SECRET=abcdef1234567890abcdef1234567890

# ====================================
# 📊 ANALYTICS & TRACKING
# ====================================
# Google Analytics 4
# 1. Ir a https://analytics.google.com/
# 2. Crear cuenta y propiedad
# 3. En Admin → Data Streams → Web
# 4. Copiar Measurement ID (formato: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Pixel)
# 1. Ir a https://business.facebook.com/
# 2. Events Manager → Data Sources → Pixels
# 3. Crear nuevo pixel o seleccionar existente
# 4. Copiar Pixel ID (número de 15-16 dígitos)
# ✅ VENTAJA: Con Facebook Login, el tracking es MÁS PRECISO
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# ====================================
# 🐛 SENTRY ERROR TRACKING
# ====================================
# Monitoreo de errores en producción - https://sentry.io
# 1. Crear cuenta en https://sentry.io
# 2. Crear proyecto Next.js
# 3. Obtener DSN en Settings → SDK Setup → Client Keys
# 4. Crear Auth Token en Settings → Account → API → Create Token
#    Scopes necesarios: project:read, project:write, org:read, releases:read, releases:write

# DSN público (seguro exponer en el cliente)
NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org-id].ingest.sentry.io/[project-id]

# Variables privadas (NUNCA exponer en el cliente)
SENTRY_AUTH_TOKEN=sntrys_[tu-token-aqui]
SENTRY_ORG=[tu-org-slug]
SENTRY_PROJECT=[tu-project-slug]

# ====================================
# ⚙️ CONFIGURACIÓN DE ENTORNO
# ====================================
# Valores: development | production | test
NODE_ENV=development

# URL pública de tu aplicación (para PWA y redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================================
# 📱 PWA (Opcional)
# ====================================
# Activa/desactiva el Service Worker
NEXT_PUBLIC_PWA_ENABLED=true

# ====================================
# 🔔 NOTIFICACIONES (Futuro)
# ====================================
# Para implementación futura de push notifications
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ====================================
# 💳 PAGOS (Futuro)
# ====================================
# Para integración con Stripe o MercadoPago
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=

# ====================================
# 📧 RESEND EMAIL SERVICE
# ====================================
# Servicio de envío de emails - https://resend.com
# 1. Crear cuenta en https://resend.com
# 2. Ir a API Keys en el dashboard
# 3. Crear nueva API key
# 4. Copiar y pegar aquí
# Nota: El email por defecto es onboarding@resend.dev (gratis)
# Para producción: Verificar dominio propio en Resend

RESEND_API_KEY=re_[tu-api-key-aqui]