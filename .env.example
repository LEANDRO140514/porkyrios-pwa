# =============================================================
# 🔐 VARIABLES DE ENTORNO - PORKYRIOS PWA
# =============================================================
# Copia este archivo como .env y configura tus credenciales.
# ⚠️  NUNCA subas el archivo .env a git/GitHub.
# =============================================================

# ====================================
# 🌐 URL DE LA APLICACIÓN
# ====================================
# Cambia a tu dominio real en producción
# Afecta: MercadoPago back_urls, OAuth redirects, webhooks

NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# ====================================
# 🔐 AUTENTICACIÓN (Better Auth)
# ====================================
# Genera un secreto aleatorio seguro:
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   Online:  https://generate-secret.vercel.app/32

BETTER_AUTH_SECRET=tu-secreto-aleatorio-aqui

# ====================================
# 🗄️ BASE DE DATOS - TURSO (SQLite en la nube)
# ====================================
# 1. Crear cuenta en https://turso.tech
# 2. Crear base de datos: turso db create porkyrios
# 3. Obtener URL: turso db show porkyrios --url
# 4. Crear token: turso db tokens create porkyrios

TURSO_CONNECTION_URL=libsql://[tu-database].aws-us-west-2.turso.io
TURSO_AUTH_TOKEN=eyJhbGci...tu-token-aqui

# ====================================
# 💳 MERCADOPAGO
# ====================================
# 1. Crear cuenta en https://www.mercadopago.com.mx/developers
# 2. Ir a Tus integraciones → Crear aplicación
# 3. Credenciales de producción → Access Token
# ⚠️  El token empieza con APP_USR- (producción) o TEST- (sandbox)
# 4. Configurar webhook en el panel de MercadoPago:
#    URL: https://tudominio.com/api/payment/webhook
#    Evento: payment

MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu-access-token-aqui

# ====================================
# 🔑 GOOGLE OAUTH
# ====================================
# 1. Ir a https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins:
#    - http://localhost:3000  (desarrollo)
#    - https://tudominio.com  (producción)
# 5. Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google  (desarrollo)
#    - https://tudominio.com/api/auth/callback/google  (producción)

GOOGLE_CLIENT_ID=525878187764-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ====================================
# 🔵 FACEBOOK OAUTH
# ====================================
# 1. Ir a https://developers.facebook.com → My Apps → Create App
# 2. App Type: Business → Use case: Facebook Login
# 3. Settings → Basic → Copiar App ID y App Secret
# 4. Facebook Login → Settings → Valid OAuth Redirect URIs:
#    - http://localhost:3000/api/auth/callback/facebook  (desarrollo)
#    - https://tudominio.com/api/auth/callback/facebook  (producción)

FACEBOOK_CLIENT_ID=tu-app-id
FACEBOOK_CLIENT_SECRET=tu-app-secret

# ====================================
# 📧 RESEND (Envío de emails)
# ====================================
# 1. Crear cuenta en https://resend.com
# 2. API Keys → Create API Key
# 3. Para producción: verificar tu dominio en Resend
#    (Resend → Domains → Add Domain → agregar registros DNS)

RESEND_API_KEY=re_tu-api-key-aqui

# ====================================
# 🐛 SENTRY (Monitoreo de errores)
# ====================================
# 1. Crear cuenta en https://sentry.io
# 2. Create Project → Next.js
# 3. DSN: Settings → SDK Setup → Client Keys (DSN)
# 4. Auth Token: Settings → Account → API → Create Token
#    Scopes: project:read, project:write, org:read, releases:read/write

NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project-id]
SENTRY_ORG=tu-org-slug
SENTRY_PROJECT=tu-project-slug
SENTRY_AUTH_TOKEN=sntrys_tu-token-aqui

# ====================================
# 🤖 GHL - GoHighLevel (CRM)
# ====================================
# Solo requerido si el cliente acepta usar una subcuenta de GHL
# 1. Ir a GHL → Settings → Integrations → API Keys
# 2. Crear API Key para la subcuenta (Location)
# 3. Obtener el Location ID en Settings → Business Info

GHL_API_KEY=tu-ghl-api-key
GHL_LOCATION_ID=tu-location-id
GHL_ENABLED=false

# ====================================
# 📊 GOOGLE ANALYTICS / TAG MANAGER
# ====================================
# Google Analytics 4:
# 1. https://analytics.google.com → Crear propiedad
# 2. Admin → Data Streams → Web → Measurement ID (G-XXXXXXXXXX)

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager (alternativa):
# 1. https://tagmanager.google.com → Crear cuenta
# 2. Copiar Container ID (GTM-XXXXXXX)

NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ====================================
# 🔔 NOTIFICACIONES PUSH (WebPush/VAPID)
# ====================================
# Generar claves VAPID:
#   npx web-push generate-vapid-keys
# Actualmente el SW usa las notificaciones nativas del navegador.
# Estas variables se necesitan si implementas un servidor push propio.

NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key
